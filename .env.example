# true にするとローカルの Firebase Emulator に接続する(開発用)
VITE_FIREBASE_USE_EMULATORS=true

# 本番 Firebase プロジェクトの設定値(Firebase コンソール > プロジェクトの設定 > 全般)
# VITE_FIREBASE_USE_EMULATORS=false の場合に必須
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase コンソール > プロジェクトの設定 > 全般 > 全般タブ下部の「Google アナリティクス」
# (Analytics 有効化後に発行される測定 ID)。未設定・エミュレータ利用時は Analytics を初期化しない(Issue #18)
VITE_FIREBASE_MEASUREMENT_ID=

# Sentry プロジェクト(フロントエンド用)の DSN。未設定・エミュレータ利用時は Sentry を初期化しない(Issue #18)
VITE_SENTRY_DSN=

# Firebase コンソール > App Check > アプリ登録で発行される reCAPTCHA v3 サイトキー。
# 未設定・エミュレータ利用時は App Check を初期化しない(Issue #16)
VITE_FIREBASE_APPCHECK_SITE_KEY=
