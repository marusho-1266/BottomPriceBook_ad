rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 悪用・スパム対策(Issue #16)のフィールド検証共通ヘルパー。
    // トップレベルに定義し、invites(books スコープ外)からも利用する。
    // 数値型は値の大小でストレージコストが変わらないため上限は設けない
    function isValidString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }
    function isValidOptionalString(data, key, maxLen) {
      return !(key in data) || (data[key] is string && data[key].size() <= maxLen);
    }

    // 招待コード。ドキュメント ID(自動 ID)自体が秘密トークンのため、
    // get は認証済なら許可するが list は禁止(コードの列挙防止)
    match /invites/{inviteCode} {
      allow get: if request.auth != null;
      allow list: if false;

      // 対象 book のオーナーのみ発行可。createdAt は serverTimestamp 必須(クライアント時計に依存しない)。
      // 有効期限は join 側で createdAt + 7 日を request.time と比較する
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.bookId is string
        && get(/databases/$(database)/documents/books/$(request.resource.data.bookId))
            .data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['bookId', 'bookName', 'createdBy', 'createdAt'])
        && isValidString(request.resource.data.bookName, 1, 100)
        && request.resource.data.createdAt == request.time;

      // 期限延長を防ぐため update は不可。削除は発行者のみ
      allow update: if false;
      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    match /books/{bookId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberUids;
      }
      // book ドキュメントを get して member か判定(サブコレクション用)
      function isBookMember() {
        return request.auth != null
          && request.auth.uid
            in get(/databases/$(database)/documents/books/$(bookId)).data.memberUids;
      }
      // book 作成と同一トランザクション内の書き込み(シード)も許可するため getAfter を使う
      function isBookMemberAfterWrite() {
        return request.auth != null
          && request.auth.uid
            in getAfter(/databases/$(database)/documents/books/$(bookId)).data.memberUids;
      }
      // アカウント削除(Issue #13)の recursiveDelete 実行中は書き込みを一切禁止し、
      // 並行書き込みが親 book 削除後に孤児ドキュメントとして残る競合を防ぐ。
      // book 作成トランザクション中(book 未作成)は exists() で短絡し false を返す
      // (get() は存在しないドキュメントへのアクセスでエラーになるため)
      function bookIsDeleting() {
        return exists(/databases/$(database)/documents/books/$(bookId))
          && get(/databases/$(database)/documents/books/$(bookId)).data.get('deleting', false) == true;
      }
      // 招待コードがこの book のもので期限内かを検証(Issue #7)。
      // 上限 7 日はサーバー時刻 request.time と createdAt(serverTimestamp) で判定する
      function isValidInviteFor(code) {
        return code is string
          && get(/databases/$(database)/documents/invites/$(code)).data.bookId == bookId
          && request.time
            < get(/databases/$(database)/documents/invites/$(code)).data.createdAt
              + duration.value(7, 'd');
      }
      // 参加(join): 「memberUids のみ・自分の uid の追加のみ」の更新を、
      // 同一バッチで書かれた joinTokens doc の招待コードを getAfter で読んで検証する。
      // affectedKeys で任意フィールドの追加・変更も拒否する
      function isSelfJoinWithInvite() {
        return request.auth != null
          && !(request.auth.uid in resource.data.memberUids)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
          && request.resource.data.memberUids.toSet()
            == resource.data.memberUids.toSet().union([request.auth.uid].toSet())
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
          && isValidInviteFor(
            getAfter(
              /databases/$(database)/documents/books/$(bookId)/joinTokens/$(request.auth.uid))
              .data.inviteCode);
      }

      // 巨大ドキュメント・任意フィールドの書込を防ぐ(Issue #16)。
      // deleting はサーバー(Admin SDK)専用の任意フィールドのため許可リストに含める
      function isValidBook() {
        return request.resource.data.keys().hasOnly(
            ['name', 'ownerUid', 'memberUids', 'bottomWindowMonths', 'createdAt', 'deleting'])
          && isValidString(request.resource.data.name, 1, 100)
          && request.resource.data.memberUids.size() <= 20;
      }

      // 自分の bookId は未作成でも読める(初期化時の存在確認に必要)。それ以外はメンバーのみ
      allow read: if isSignedIn() && (bookId == request.auth.uid || isMember());

      // MVP では bookId = uid の決定的 ID のみ許可(H-4)
      allow create: if isSignedIn()
        && bookId == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.get('deleting', false) == false
        && isValidBook();

      // 退出: memberUids のみ・自分の uid の除去のみ。オーナー自身は退出不可(Issue #7)。
      // affectedKeys で任意フィールドの追加・変更も拒否する
      function isSelfLeave() {
        return request.auth != null
          && request.auth.uid in resource.data.memberUids
          && request.auth.uid != resource.data.ownerUid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
          && request.resource.data.memberUids.toSet()
            == resource.data.memberUids.toSet().difference([request.auth.uid].toSet())
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1;
      }

      // ownerUid / createdAt は不変。memberUids の変更は owner のみ(M-3)。
      // owner による変更でも owner 自身は memberUids から外せない(Issue #7)。
      // 例外として、有効な招待コードによる参加と本人の退出を許可(Issue #7)。
      // deleting はサーバー(Admin SDK、ルール非適用)専用フラグのため
      // クライアントからの変更を一切禁止する(永続 DoS 防止)
      allow update: if resource.data.get('deleting', false) != true
        && !('deleting' in request.resource.data.diff(resource.data).affectedKeys())
        && isValidBook()
        && ((isMember()
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.createdAt == resource.data.createdAt
          && (request.resource.data.memberUids == resource.data.memberUids
            || (request.auth.uid == resource.data.ownerUid
              && resource.data.ownerUid in request.resource.data.memberUids)))
          || isSelfJoinWithInvite()
          || isSelfLeave());

      allow delete: if false;

      match /categories/{categoryId} {
        // 巨大ドキュメント・任意フィールドの書込を防ぐ(Issue #16)
        function isValidCategory() {
          return request.resource.data.keys().hasOnly(['name', 'baseUnit', 'sortOrder'])
            && isValidString(request.resource.data.name, 1, 100)
            && request.resource.data.baseUnit in ['g', 'ml', '個', '枚', '組', '回分']
            && request.resource.data.sortOrder is int
            && request.resource.data.sortOrder >= 0;
        }

        allow read: if isBookMember();
        // book 作成トランザクションでのシード書き込みがあるため getAfter 判定
        allow create, update: if isBookMemberAfterWrite() && !bookIsDeleting() && isValidCategory();
        allow delete: if isBookMemberAfterWrite() && !bookIsDeleting();
      }

      // メンバープロフィール(表示名のみ。Issue #7)。
      // メンバーシップの真実のソースはあくまで books.memberUids。
      // 招待コードは秘密情報のためここには置かない(joinTokens に分離)
      match /members/{memberUid} {
        allow read: if isBookMember();
        // 本人のみ作成可。join バッチでは book 側の isSelfJoinWithInvite が招待を検証し、
        // getAfter でメンバーになるため可。単独作成は既存メンバーの補完のみ
        allow create: if request.auth != null
          && request.auth.uid == memberUid
          && request.resource.data.keys().hasOnly(['displayName', 'joinedAt'])
          && isValidString(request.resource.data.displayName, 1, 100)
          && isBookMemberAfterWrite()
          && !bookIsDeleting();
        // 表示名の書き換えを防ぐため update は不可
        allow update: if false;
        // 退出(本人)またはオーナーによる削除
        allow delete: if request.auth != null
          && !bookIsDeleting()
          && (request.auth.uid == memberUid
            || request.auth.uid
              == get(/databases/$(database)/documents/books/$(bookId)).data.ownerUid);
      }

      // 参加検証用の招待コード置き場(Issue #7)。コード自体が秘密情報のため誰も読めない。
      // book update の isSelfJoinWithInvite が同一バッチ内の doc を getAfter で参照する
      match /joinTokens/{memberUid} {
        allow read: if false;
        // 本人のみ・有効な招待コードのみ・フィールドは inviteCode のみ
        allow create: if request.auth != null
          && request.auth.uid == memberUid
          && request.resource.data.keys().hasOnly(['inviteCode'])
          && isValidInviteFor(request.resource.data.inviteCode)
          && !bookIsDeleting();
        // コードのすり替えを防ぐため update は不可
        allow update: if false;
        // 退出(本人)またはオーナーによる削除(members doc と同じ掃除経路)
        allow delete: if request.auth != null
          && !bookIsDeleting()
          && (request.auth.uid == memberUid
            || request.auth.uid
              == get(/databases/$(database)/documents/books/$(bookId)).data.ownerUid);
      }

      match /stores/{storeId} {
        // 巨大ドキュメント・任意フィールドの書込を防ぐ(Issue #16)
        function isValidStore() {
          return request.resource.data.keys().hasOnly(['name'])
            && isValidString(request.resource.data.name, 1, 100);
        }

        allow read: if isBookMember();
        allow create, update: if isBookMember() && !bookIsDeleting() && isValidStore();
        allow delete: if isBookMember() && !bookIsDeleting();
      }

      match /products/{productId} {
        // 巨大ドキュメント・任意フィールドの書込を防ぐ(Issue #16)
        function isValidProduct() {
          return request.resource.data.keys().hasOnly(['name', 'categoryId', 'note'])
            && isValidString(request.resource.data.name, 1, 100)
            && isValidString(request.resource.data.categoryId, 1, 100)
            && isValidOptionalString(request.resource.data, 'note', 500);
        }

        allow read: if isBookMember();
        allow create, update: if isBookMember() && !bookIsDeleting() && isValidProduct();
        allow delete: if isBookMember() && !bookIsDeleting();
      }

      match /priceRecords/{recordId} {
        // price / quantity は正の数かつ上限あり、フィールドは許可リストのみ(M-3 / Issue #16)
        function isValidRecord() {
          return request.resource.data.keys().hasOnly(
              ['productId', 'storeId', 'price', 'quantity', 'unit', 'isSale', 'recordedAt', 'note'])
            && isValidString(request.resource.data.productId, 1, 100)
            && isValidString(request.resource.data.storeId, 1, 100)
            && request.resource.data.price is number
            && request.resource.data.price > 0
            && request.resource.data.price <= 10000000
            && request.resource.data.quantity is number
            && request.resource.data.quantity > 0
            && request.resource.data.quantity <= 1000000
            && isValidString(request.resource.data.unit, 1, 100)
            && request.resource.data.isSale is bool
            && request.resource.data.recordedAt is timestamp
            && isValidOptionalString(request.resource.data, 'note', 500);
        }

        allow read, delete: if isBookMember();
        allow create, update: if isBookMember() && isValidRecord() && !bookIsDeleting();
      }
    }
  }
}
