rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 招待コード。ドキュメント ID(自動 ID)自体が秘密トークンのため、
    // get は認証済なら許可するが list は禁止(コードの列挙防止)
    match /invites/{inviteCode} {
      allow get: if request.auth != null;
      allow list: if false;

      // 対象 book のオーナーのみ発行可。期限は未来かつ 8 日以内(クライアント時計ずれの許容込み)
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.bookId is string
        && get(/databases/$(database)/documents/books/$(request.resource.data.bookId))
            .data.ownerUid == request.auth.uid
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt <= request.time + duration.value(8, 'd');

      // 期限延長を防ぐため update は不可。削除は発行者のみ
      allow update: if false;
      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    match /books/{bookId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberUids;
      }
      // book ドキュメントを get して member か判定(サブコレクション用)
      function isBookMember() {
        return request.auth != null
          && request.auth.uid
            in get(/databases/$(database)/documents/books/$(bookId)).data.memberUids;
      }
      // book 作成と同一トランザクション内の書き込み(シード)も許可するため getAfter を使う
      function isBookMemberAfterWrite() {
        return request.auth != null
          && request.auth.uid
            in getAfter(/databases/$(database)/documents/books/$(bookId)).data.memberUids;
      }
      // 招待コードがこの book のもので期限内かを検証(Issue #7)
      function isValidInviteFor(code) {
        return code is string
          && get(/databases/$(database)/documents/invites/$(code)).data.bookId == bookId
          && request.time
            < get(/databases/$(database)/documents/invites/$(code)).data.expiresAt;
      }
      // 参加(join): 「自分の uid の追加のみ + 他フィールド不変」の更新を、
      // 同一バッチで書かれた members doc の招待コードを getAfter で読んで検証する
      function isSelfJoinWithInvite() {
        return request.auth != null
          && !(request.auth.uid in resource.data.memberUids)
          && request.resource.data.memberUids.toSet()
            == resource.data.memberUids.toSet().union([request.auth.uid].toSet())
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
          && request.resource.data.name == resource.data.name
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.bottomWindowMonths == resource.data.bottomWindowMonths
          && isValidInviteFor(
            getAfter(/databases/$(database)/documents/books/$(bookId)/members/$(request.auth.uid))
              .data.inviteCode);
      }

      // 自分の bookId は未作成でも読める(初期化時の存在確認に必要)。それ以外はメンバーのみ
      allow read: if isSignedIn() && (bookId == request.auth.uid || isMember());

      // MVP では bookId = uid の決定的 ID のみ許可(H-4)
      allow create: if isSignedIn()
        && bookId == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      // 退出: 自分の uid の除去のみ + 他フィールド不変。オーナー自身は退出不可(Issue #7)
      function isSelfLeave() {
        return request.auth != null
          && request.auth.uid in resource.data.memberUids
          && request.auth.uid != resource.data.ownerUid
          && request.resource.data.memberUids.toSet()
            == resource.data.memberUids.toSet().difference([request.auth.uid].toSet())
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() - 1
          && request.resource.data.name == resource.data.name
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.bottomWindowMonths == resource.data.bottomWindowMonths;
      }

      // ownerUid / createdAt は不変。memberUids の変更は owner のみ(M-3)。
      // owner による変更でも owner 自身は memberUids から外せない(Issue #7)。
      // 例外として、有効な招待コードによる参加と本人の退出を許可(Issue #7)
      allow update: if (isMember()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt
        && (request.resource.data.memberUids == resource.data.memberUids
          || (request.auth.uid == resource.data.ownerUid
            && resource.data.ownerUid in request.resource.data.memberUids)))
        || isSelfJoinWithInvite()
        || isSelfLeave();

      allow delete: if false;

      match /categories/{categoryId} {
        allow read: if isBookMember();
        // book 作成トランザクションでのシード書き込みがあるため getAfter 判定
        allow write: if isBookMemberAfterWrite();
      }

      // メンバープロフィール(表示名 + join のルール検証マーカー)(Issue #7)。
      // メンバーシップの真実のソースはあくまで books.memberUids
      match /members/{memberUid} {
        allow read: if isBookMember();
        // 本人のみ作成可。join バッチ中は book 側の isSelfJoinWithInvite が招待を検証するため
        // getAfter でメンバーになっていれば可。単独作成は既存メンバーの補完か有効な招待が必要
        allow create: if request.auth != null
          && request.auth.uid == memberUid
          && request.resource.data.displayName is string
          && (isBookMemberAfterWrite()
            || isValidInviteFor(request.resource.data.inviteCode));
        // 表示名の書き換えや招待コードのすり替えを防ぐため update は不可
        allow update: if false;
        // 退出(本人)またはオーナーによる削除
        allow delete: if request.auth != null
          && (request.auth.uid == memberUid
            || request.auth.uid
              == get(/databases/$(database)/documents/books/$(bookId)).data.ownerUid);
      }

      match /stores/{storeId} {
        allow read, write: if isBookMember();
      }

      match /products/{productId} {
        allow read, write: if isBookMember();
      }

      match /priceRecords/{recordId} {
        // price / quantity は正の数(M-3)。上限等の業務バリデーションはクライアント責務
        function isValidRecord() {
          return request.resource.data.price is number
            && request.resource.data.price > 0
            && request.resource.data.quantity is number
            && request.resource.data.quantity > 0;
        }

        allow read, delete: if isBookMember();
        allow create, update: if isBookMember() && isValidRecord();
      }
    }
  }
}
