rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /books/{bookId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberUids;
      }

      // 自分の bookId は未作成でも読める(初期化時の存在確認に必要)。
      // それ以外はメンバーのみ
      allow read: if isSignedIn() && (bookId == request.auth.uid || isMember());

      // MVP では bookId = uid の決定的 ID のみ許可(H-4)
      allow create: if isSignedIn()
        && bookId == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      // ownerUid / createdAt は不変。memberUids の変更は owner のみ(M-3)
      allow update: if isMember()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt
        && (request.resource.data.memberUids == resource.data.memberUids
          || request.auth.uid == resource.data.ownerUid);

      allow delete: if false;

      // book 配下のサブコレクション(categories / stores / products / priceRecords)
      match /{collection}/{docId} {
        function isSignedIn() {
          return request.auth != null;
        }
        // 書き込みは book 作成と同一トランザクションのシードも許可するため getAfter を使う
        function isMemberAfterWrite() {
          return isSignedIn()
            && request.auth.uid
              in getAfter(/databases/$(database)/documents/books/$(bookId)).data.memberUids;
        }
        function isMemberNow() {
          return isSignedIn()
            && request.auth.uid
              in get(/databases/$(database)/documents/books/$(bookId)).data.memberUids;
        }

        allow read: if isMemberNow();
        allow write: if isMemberAfterWrite();
      }
    }
  }
}
